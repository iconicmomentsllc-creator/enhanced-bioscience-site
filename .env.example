# Copy to .env.local for local development (never commit real secrets).

# Where access-request form emails are delivered (defaults to enhancedbioscience@gmail.com)
# ACCESS_REQUEST_TO=you@example.com

# SMTP — required for /request-access to send mail (e.g. Gmail app password, SendGrid SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Enhanced Bioscience <youraddress@gmail.com>"

# Existing member portal (optional overrides)
# MEMBER_ACCESS_CODE=EBS2026
# MEMBER_SESSION_SECRET=long-random-string
