# Copy to .env.local (never commit real secrets).

# Database — SQLite file on disk: prisma/dev.db (ignored by git).
# Path is relative to prisma/schema.prisma; "file:../prisma/dev.db" always resolves there (not the repo root).
DATABASE_URL="file:../prisma/dev.db"

# Auth — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Membership access code — must match what you send members after they request access (required to create an account)
# MEMBER_ACCESS_CODE=EBS2026

# Where access-request form emails are delivered (defaults to enhancedbioscience@gmail.com)
# ACCESS_REQUEST_TO=you@example.com

# SMTP — required for /request-access to send mail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Enhanced Bioscience <youraddress@gmail.com>"

# Production (Vercel, etc.): set NEXTAUTH_URL to your public URL.
# For Postgres instead of SQLite, change prisma/schema.prisma provider to postgresql,
# set DATABASE_URL to your connection string, then run: npx prisma migrate deploy
