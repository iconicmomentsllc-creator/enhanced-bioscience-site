# Copy to .env.local (never commit real secrets).

# Database — PostgreSQL connection string (Neon, Supabase, RDS, local Docker, etc.)
# Example Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/enhanced_bioscience?schema=public"

# Auth — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Membership access code — must match what you send members after they request access (required to create an account)
# MEMBER_ACCESS_CODE=EBS2026

# Where access-request form emails are delivered (defaults to enhancedbioscience@gmail.com)
# ACCESS_REQUEST_TO=you@example.com

# SMTP — required for /request-access to send mail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Enhanced Bioscience <youraddress@gmail.com>"

# Production: set NEXTAUTH_URL to your public https URL.
# After changing schema, run once against your DB: npx prisma migrate deploy
